# Datalogger Industrial M594 - Variables de Entorno
# Copiar este archivo a .env y configurar los valores apropiados

# =============================================================================
# CONFIGURACIÓN OPC UA
# =============================================================================
# Endpoint del servidor OPC UA integrado en el PLC M594
OPC_ENDPOINT=opc.tcp://192.168.20.30:4840

# =============================================================================
# CONFIGURACIÓN BASE DE DATOS MYSQL
# =============================================================================
# Servidor MySQL (reemplazar con IP real del servidor)
MYSQL_HOST=192.168.0.183
MYSQL_PORT=3306
MYSQL_DB=industrial_db
MYSQL_USER=root
MYSQL_PASSWORD=

# =============================================================================
# CONFIGURACIÓN DE LOGGING
# =============================================================================
# Nivel de logging: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# CONFIGURACIÓN OPCIONAL
# =============================================================================
# Archivo de configuración de tags (ruta relativa al directorio del script)
TAGS_JSON=tags.json

# Archivo de configuración de eventos (ruta relativa al directorio del script)
CONFIG_TABLAS_ESPECIALIZADAS=config_tablas_especializadas.json

# =============================================================================
# NOTAS DE CONFIGURACIÓN
# =============================================================================
# 1. Cambiar OPC_ENDPOINT si el PLC tiene dirección IP diferente
# 2. Configurar MYSQL_HOST, MYSQL_USER, MYSQL_PASSWORD según tu entorno
# 3. Para MySQL 8.0+, puede ser necesario cambiar el método de autenticación:
#    ALTER USER 'root'@'%' IDENTIFIED WITH mysql_native_password BY 'tu_password';
# 4. Para desarrollo, usar LOG_LEVEL=DEBUG para más detalles
# 5. Asegurarse que el PLC M594 tenga el servidor OPC UA activo y accesible
# 6. La base de datos por defecto es 'industrial_db' (no 'm594')
